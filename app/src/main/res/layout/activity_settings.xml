<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <!-- Top App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorSurface"
            app:title="@string/privacy_settings"
            app:titleTextAppearance="@style/TextAppearance.JAVBrowser.HeadlineSmall"
            app:titleCentered="true"
            app:navigationIcon="@drawable/ic_back"
            app:titleTextColor="?attr/colorOnSurface" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nested_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md"
            android:paddingBottom="100dp">

            <!-- ==================== Ad Blocking Section ==================== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_ad_filtering"
                style="@style/Widget.Material3.CardView.Elevated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                app:cardCornerRadius="24dp"
                app:cardElevation="@dimen/elevation_sm">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.example.freeavbrowser.SettingsGroupTitle
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:groupTitle="@string/ad_filter_rules" />

                    <!-- Ad Blocking Switch -->
                    <com.example.freeavbrowser.SettingsSwitchRow
                        android:id="@+id/switch_ad_blocking"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:settingsIcon="@drawable/ic_block"
                        app:settingsTitle="@string/ad_blocking"
                        app:settingsSubtitle="拦截网页广告"
                        app:settingsChecked="true" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="68dp"
                        android:layout_marginEnd="20dp"
                        android:background="?attr/colorOutlineVariant"
                        android:alpha="0.5" />

                    <!-- Ad Rules (Expandable) -->
                    <com.example.freeavbrowser.SettingsNavRow
                        android:id="@+id/item_ad_rules"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:settingsIcon="@drawable/ic_list"
                        app:settingsTitle="@string/ad_filter_rules"
                        app:settingsSubtitle="@string/rules_loading" />

                    <!-- Expandable Rules Panel -->
                    <LinearLayout
                        android:id="@+id/panel_ad_rules"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="68dp"
                        android:paddingEnd="20dp"
                        android:paddingBottom="16dp"
                        android:visibility="gone"
                        android:background="?attr/colorSurfaceContainerLow">

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/cloud_url_hint"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="12dp"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_rule_url"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textUri"
                                android:maxLines="1" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_add_rule"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:text="@string/add_rule"
                            app:icon="@drawable/ic_add" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/rules_list_placeholder"
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:padding="12dp"
                            android:background="?attr/colorSurfaceContainerHigh"
                            android:layout_marginBottom="8dp"
                            android:drawableStart="@drawable/ic_info"
                            android:drawablePadding="8dp"
                            app:drawableTint="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="68dp"
                        android:layout_marginEnd="20dp"
                        android:background="?attr/colorOutlineVariant"
                        android:alpha="0.5" />

                    <!-- Update Rules -->
                    <com.example.freeavbrowser.SettingsNavRow
                        android:id="@+id/item_update_rules"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:settingsIcon="@drawable/ic_download"
                        app:settingsTitle="@string/update_rules"
                        app:settingsSubtitle="@string/update_rules_subtitle" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="20dp"
                        android:layout_marginEnd="20dp"
                        android:background="?attr/colorOutlineVariant"
                        android:alpha="0.5" />

                    <!-- EasyList Toggle -->
                    <com.example.freeavbrowser.SettingsSwitchRow
                        android:id="@+id/switch_easylist"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:settingsIcon="@drawable/ic_block"
                        app:settingsTitle="启用 EasyList 规则"
                        app:settingsSubtitle="从云端下载补充规则（12万+ 规则）" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_download_easylist"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="20dp"
                        android:layout_marginEnd="20dp"
                        android:layout_marginBottom="16dp"
                        android:text="下载 EasyList 规则"
                        android:enabled="false"
                        app:icon="@drawable/ic_download"
                        style="@style/Widget.Material3.Button.TonalButton" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ==================== Privacy & Security Section ==================== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_privacy"
                style="@style/Widget.Material3.CardView.Elevated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                app:cardCornerRadius="24dp"
                app:cardElevation="@dimen/elevation_sm">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.example.freeavbrowser.SettingsGroupTitle
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:groupTitle="@string/privacy_security" />

                    <com.example.freeavbrowser.SettingsSwitchRow
                        android:id="@+id/switch_lock"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:settingsIcon="@drawable/ic_lock"
                        app:settingsTitle="@string/app_lock"
                        app:settingsSubtitle="@string/app_lock_subtitle"
                        app:settingsChecked="true" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="68dp"
                        android:layout_marginEnd="20dp"
                        android:background="?attr/colorOutlineVariant"
                        android:alpha="0.5" />

                    <com.example.freeavbrowser.SettingsSwitchRow
                        android:id="@+id/switch_screenshot_block"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:settingsIcon="@drawable/ic_shield"
                        app:settingsTitle="@string/screenshot_block"
                        app:settingsSubtitle="启用后禁止截屏和录屏" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="68dp"
                        android:layout_marginEnd="20dp"
                        android:background="?attr/colorOutlineVariant"
                        android:alpha="0.5" />

                    <com.example.freeavbrowser.SettingsSwitchRow
                        android:id="@+id/switch_biometric"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:settingsIcon="@drawable/ic_fingerprint"
                        app:settingsTitle="@string/enable_biometric"
                        app:settingsSubtitle="使用指纹识别解锁"
                        app:settingsChecked="true" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="68dp"
                        android:layout_marginEnd="20dp"
                        android:background="?attr/colorOutlineVariant"
                        android:alpha="0.5" />

                    <com.example.freeavbrowser.SettingsSwitchRow
                        android:id="@+id/switch_cloudflare_bypass"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:settingsIcon="@drawable/ic_shield"
                        app:settingsTitle="Cloudflare 绕过"
                        app:settingsSubtitle="自动提取验证 Cookie" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="68dp"
                        android:layout_marginEnd="20dp"
                        android:background="?attr/colorOutlineVariant"
                        android:alpha="0.5" />

                    <com.example.freeavbrowser.SettingsSwitchRow
                        android:id="@+id/switch_privacy_mode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:settingsIcon="@drawable/ic_privacy"
                        app:settingsTitle="@string/privacy_mode"
                        app:settingsSubtitle="@string/privacy_mode_subtitle" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ==================== App Disguise Section ==================== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_app_icon"
                style="@style/Widget.Material3.CardView.Elevated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                app:cardCornerRadius="24dp"
                app:cardElevation="@dimen/elevation_sm">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.example.freeavbrowser.SettingsGroupTitle
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:groupTitle="@string/app_icon" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:paddingBottom="12dp"
                        android:text="@string/icon_description"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:lineSpacingMultiplier="1.5" />

                    <!-- Icon Selector Grid (keep as-is) -->
                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="20dp"
                        android:layout_marginEnd="20dp"
                        android:layout_marginBottom="20dp"
                        android:columnCount="4"
                        android:rowCount="1"
                        android:alignmentMode="alignBounds"
                        android:columnOrderPreserved="false"
                        android:useDefaultMargins="true">

                        <FrameLayout
                            android:id="@+id/icon_default"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:background="@drawable/bg_icon_option"
                            android:clickable="true"
                            android:focusable="true"
                            android:padding="12dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                                <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_default" app:tint="?attr/colorOnSurfaceVariant" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="@string/icon_default" android:textAppearance="@style/TextAppearance.Material3.LabelSmall" android:textColor="?attr/colorOnSurfaceVariant" android:textStyle="bold" android:letterSpacing="0.05" />
                            </LinearLayout>
                        </FrameLayout>

                        <FrameLayout
                            android:id="@+id/icon_calculator"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:background="@drawable/bg_icon_option"
                            android:clickable="true"
                            android:focusable="true"
                            android:padding="12dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                                <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_calculator" app:tint="?attr/colorOnSurfaceVariant" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="@string/icon_calculator" android:textAppearance="@style/TextAppearance.Material3.LabelSmall" android:textColor="?attr/colorOnSurfaceVariant" android:textStyle="bold" android:letterSpacing="0.05" />
                            </LinearLayout>
                        </FrameLayout>

                        <FrameLayout
                            android:id="@+id/icon_notes"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:background="@drawable/bg_icon_option"
                            android:clickable="true"
                            android:focusable="true"
                            android:padding="12dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                                <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_notes" app:tint="?attr/colorOnSurfaceVariant" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="@string/icon_notes" android:textAppearance="@style/TextAppearance.Material3.LabelSmall" android:textColor="?attr/colorOnSurfaceVariant" android:textStyle="bold" android:letterSpacing="0.05" />
                            </LinearLayout>
                        </FrameLayout>

                        <FrameLayout
                            android:id="@+id/icon_file"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:background="@drawable/bg_icon_option"
                            android:clickable="true"
                            android:focusable="true"
                            android:padding="12dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                                <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_file" app:tint="?attr/colorOnSurfaceVariant" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="@string/icon_file" android:textAppearance="@style/TextAppearance.Material3.LabelSmall" android:textColor="?attr/colorOnSurfaceVariant" android:textStyle="bold" android:letterSpacing="0.05" />
                            </LinearLayout>
                        </FrameLayout>
                    </GridLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ==================== Display Section ==================== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_display"
                style="@style/Widget.Material3.CardView.Elevated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                app:cardCornerRadius="24dp"
                app:cardElevation="@dimen/elevation_sm">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.example.freeavbrowser.SettingsGroupTitle
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:groupTitle="@string/display" />

                    <!-- Dark Mode (special: toggle group, keep as-is) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:paddingBottom="14dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:minHeight="48dp">

                            <FrameLayout
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_icon_circle">
                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_dark_mode"
                                    app:tint="?attr/colorOnSurfaceVariant" />
                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="16dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="@string/dark_mode"
                                    android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                                    android:textColor="?attr/colorOnSurface" />

                                <TextView
                                    android:id="@+id/tv_dark_mode_label"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="@string/follow_system"
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                    android:textColor="?attr/colorOnSurfaceVariant" />
                            </LinearLayout>
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButtonToggleGroup
                            android:id="@+id/toggle_dark_mode"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            app:singleSelection="true"
                            app:selectionRequired="true"
                            app:checkedButton="@id/btn_system">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_system"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/follow_system"
                                android:textSize="12sp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_light"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/light_mode"
                                android:textSize="12sp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_dark"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/dark_mode_on"
                                android:textSize="12sp" />
                        </com.google.android.material.button.MaterialButtonToggleGroup>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ==================== Network Section ==================== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_network"
                style="@style/Widget.Material3.CardView.Elevated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                app:cardCornerRadius="24dp"
                app:cardElevation="@dimen/elevation_sm">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.example.freeavbrowser.SettingsGroupTitle
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:groupTitle="@string/network_settings" />

                    <com.example.freeavbrowser.SettingsNavRow
                        android:id="@+id/item_proxy_mode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:settingsIcon="@drawable/ic_network"
                        app:settingsTitle="@string/proxy_mode"
                        app:settingsSubtitle="@string/proxy_none" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ==================== Version Info ==================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="24dp"
                android:paddingBottom="32dp">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_version_icon">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_app"
                        app:tint="?attr/colorOnPrimaryContainer" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="@string/app_name"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textColor="?attr/colorOnSurface"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_version"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/version_info"
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:letterSpacing="0.03" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
